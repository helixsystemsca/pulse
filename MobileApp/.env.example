# Same API origin as the web Pulse app uses in NEXT_PUBLIC_API_URL (no trailing slash, no /api/v1 suffix).
# If the web app is on Vercel but the API is elsewhere, point this at the API host — not the marketing site.
EXPO_PUBLIC_API_BASE_URL=https://your-pulse-api.example.com

# Optional: mirror web NEXT_PUBLIC_PULSE_LOGIN_EMAIL_DOMAIN so "jsmith" here becomes jsmith@yourcompany.com
# (required if you log into the web app with a short username instead of a full email).
# EXPO_PUBLIC_PULSE_LOGIN_EMAIL_DOMAIN=yourcompany.com

# Disable mock BLE proximity prompts by default. Turn ON only for UX development.
# EXPO_PUBLIC_MOCK_BLE=true
