# Pulse app origin (sign-in, dashboard); CTAs from www point here. No trailing slash.
# Browser origin of this Next app (Panorama). Middleware also treats panorama.* + pulse.* as app hosts unless overridden.
NEXT_PUBLIC_PULSE_APP_URL=https://panorama.helixsystems.ca
# Optional: comma-separated hostnames only (overrides built-in list). Example: panorama.helixsystems.ca,pulse.helixsystems.ca
# PULSE_APP_HOSTNAMES=

# Marketing site (home, /pulse product page, /#contact). Used from login footer, etc.
NEXT_PUBLIC_HELIX_MARKETING_URL=https://www.helixsystems.ca

# Pulse UI (App Router) — FastAPI backend for JWT login + /pulse APIs (no trailing slash).
# Example: http://127.0.0.1:8000
# API origin only (no /api or /api/v1 suffix), e.g. https://your-api.onrender.com
# When set, the marketing contact form posts to {NEXT_PUBLIC_API_URL}/api/public/contact (needs SMTP on API).
NEXT_PUBLIC_API_URL=

# Set to "true" to keep mock login even when NEXT_PUBLIC_API_URL is set (local UI testing).
NEXT_PUBLIC_USE_MOCK_AUTH=

# If set, a login identifier without "@" is treated as local@{domain} (e.g. jc → jc@yourcompany.local).
NEXT_PUBLIC_PULSE_LOGIN_EMAIL_DOMAIN=

# Legacy floorplan editor (`/zones-devices/blueprint`). When false, only company/system admins may open it (or set this to true for a short migration window).
NEXT_PUBLIC_ENABLE_LEGACY_BLUEPRINT_EDITOR=false
