# Origin of the Pulse product web app (no trailing slash). CTAs on this marketing site link here.
# Examples: https://pulse.helixsystems.ca  or  https://ops.helixsystems.ca
NEXT_PUBLIC_PULSE_APP_URL=https://app.helixsystems.ca

# Pulse UI (App Router) — FastAPI backend for JWT login + /pulse APIs (no trailing slash).
# Example: http://127.0.0.1:8000
NEXT_PUBLIC_API_URL=

# Set to "true" to keep mock login even when NEXT_PUBLIC_API_URL is set (local UI testing).
NEXT_PUBLIC_USE_MOCK_AUTH=

# If set, a login identifier without "@" is treated as local@{domain} (e.g. sysadmin → sysadmin@helixpulse.local).
NEXT_PUBLIC_PULSE_LOGIN_EMAIL_DOMAIN=helixpulse.local
