DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ops_intel
SECRET_KEY=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256
CORS_ORIGINS=http://localhost:3000
# development | production (production disables OpenAPI UI endpoints)
ENVIRONMENT=development
# Public self-registration is disabled; use system_admin + POST /api/system/companies.
ALLOW_PUBLIC_REGISTRATION=false
# Optional first boot: creates system_admin if none exist (development only).
bootstrap_system_admin_email=
bootstrap_system_admin_password=
# Send Strict-Transport-Security only when serving HTTPS in production.
ENABLE_HSTS=false
# Comma-separated hostnames for TrustedHostMiddleware (empty = disabled). Example: api.example.com,localhost
TRUSTED_HOSTS=

# Local storage for Pulse beacon photos (relative to backend working directory). Swap for object storage later.
PULSE_UPLOADS_DIR=var/uploads

# Temporary Pulse tenant (company_admin) — created on first API boot if user does not exist.
# Sign in from the Next app as username "sysadmin" when NEXT_PUBLIC_PULSE_LOGIN_EMAIL_DOMAIN=helixpulse.local,
# or use the full email below.
PULSE_BOOTSTRAP_TENANT_EMAIL=sysadmin@helixpulse.local
PULSE_BOOTSTRAP_TENANT_PASSWORD=HelixPulse
PULSE_BOOTSTRAP_TENANT_COMPANY_NAME=Helix Pulse

# One-shot seed for jc@helixpulse.com (run: python -m scripts.seed_sys_admin)
SYS_ADMIN_PASSWORD=
