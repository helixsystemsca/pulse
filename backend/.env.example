DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ops_intel
SECRET_KEY=change-me-to-a-long-random-string-in-production
# JWT lifetime (minutes). Default 12 aligns with Pulse’s ~10m idle sign-out; increase only if you need longer sessions without refresh.
ACCESS_TOKEN_EXPIRE_MINUTES=12
ALGORITHM=HS256
# Comma-separated browser origins (scheme + host, no trailing slash). Apex and www are different Origins.
CORS_ORIGINS=http://localhost:3000
# Production (Render): list every hostname users open in the browser to reach Pulse/marketing (each is a separate Origin).
# The origin of PULSE_APP_PUBLIC_URL (default https://pulse.helixsystems.ca) is merged automatically.
# CORS_ORIGINS=https://helixsystems.ca,https://www.helixsystems.ca,https://pulse.helixsystems.ca
# Optional: extra origins (staging, etc.) merged with the above and PULSE_APP_PUBLIC_URL.
# CORS_EXTRA_ORIGINS=
# Optional: apex + www + pulse (and any single-label subdomain) in one regex (full match on Origin):
# CORS_ORIGIN_REGEX=^https://([a-z0-9-]+\.)?helixsystems\.ca$
# Narrower: apex, www, and pulse only:
# CORS_ORIGIN_REGEX=^https://(www\.|pulse\.)?helixsystems\.ca$
# Temp testing only: allow POST /api/system/companies/bootstrap-legacy (tenant + company_admin password, no email).
# ALLOW_PASSWORD_COMPANY_BOOTSTRAP=false
# development | production (production disables OpenAPI UI endpoints)
ENVIRONMENT=development
# Public self-registration is disabled; use system_admin + POST /api/system/companies.
ALLOW_PUBLIC_REGISTRATION=false
# Optional first boot: creates system_admin if none exist (development only).
bootstrap_system_admin_email=
bootstrap_system_admin_password=
# Send Strict-Transport-Security only when serving HTTPS in production.
ENABLE_HSTS=false
# When true, reject requests unless X-Forwarded-Proto=https (or direct https://). Use behind TLS-terminating load balancers.
REQUIRE_HTTPS=false
# Comma-separated hostnames for TrustedHostMiddleware (empty = disabled). Example: api.example.com,localhost
TRUSTED_HOSTS=

# Upload storage: ``local`` (default) uses PULSE_UPLOADS_DIR on disk; ``s3`` uses S3-compatible object storage
# (AWS S3, Cloudflare R2, MinIO) so logos/avatars/equipment images survive stateless deploys.
# PULSE_STORAGE_BACKEND=local
# PULSE_S3_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
# PULSE_S3_BUCKET=your-bucket
# PULSE_S3_ACCESS_KEY_ID=
# PULSE_S3_SECRET_ACCESS_KEY=
# PULSE_S3_REGION=us-east-1
# PULSE_S3_KEY_PREFIX=pulse
PULSE_UPLOADS_DIR=var/uploads

# One-shot system admin seed: `python -m scripts.seed_sys_admin` creates/updates SYS_ADMIN_EMAIL (default below).
SYS_ADMIN_EMAIL=josh.collins@helixsystems.ca
SYS_ADMIN_PASSWORD=change-me-8-chars-min

# --- Outbound SMTP (invites, password resets, contact form). Leave SMTP_HOST empty to skip sending mail.
# Typical: Microsoft 365 / Google Workspace SMTP with an account allowed to send as noreply@helixsystems.ca.
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# SMTP_USERNAME=user@helixsystems.ca
# SMTP_PASSWORD=
# EMAIL_FROM_NOREPLY=noreply@helixsystems.ca
# EMAIL_FROM_DISPLAY=Helix Systems
# EMAIL_TO_INFO=info@helixsystems.ca
# Links in invite/reset emails + CORS merge. Must be the Pulse SPA origin in the browser, NOT the API URL.
# (Wrong: https://your-service.onrender.com — that breaks CORS for https://pulse.example.com)
# PULSE_APP_PUBLIC_URL=https://pulse.helixsystems.ca
